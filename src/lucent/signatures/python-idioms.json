      "atom": "ENVI.VAR", "surface": "callee", "method": "static-source",
      "languages": ["python"],
      "match": {"mode": "substring", "values": ["os.getenv", "os.environ"]},
      "confidence": 0.75, "priority": 40,
      "summary": "reads environment configuration",
      "notes": "os.getenv / os.environ / os.environ.get and os.environ[...] subscripts."
    },
    {
