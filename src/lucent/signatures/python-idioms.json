      "atom": "RSRC.THREAD", "surface": "callee", "method": "static-source",
      "languages": ["python"],
      "match": {"mode": "substring", "values": ["threading.thread", "multiprocessing.process", "multiprocessing.pool", "concurrent.futures", "asyncio.create_task", "asyncio.ensure_future", "asyncio.gather", "asyncio.to_thread", "_thread.start_new_thread"]},
      "confidence": 0.6, "priority": 40,
